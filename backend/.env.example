APP_ENV=development
LOG_LEVEL=INFO
REDIS_URL=redis://redis:6379/0
RATE_LIMIT_DEFAULT_PER_MINUTE=120
RATE_LIMIT_SSL_PER_MINUTE=30
RATE_LIMIT_FILE_PER_MINUTE=30
RATE_LIMIT_PDF_PER_MINUTE=15
SSL_CACHE_TTL_SECONDS=300
REQUEST_BODY_MAX_BYTES=32768
FILE_REQUEST_MAX_BYTES=26214400
SSL_CONNECT_TIMEOUT_SECONDS=4
SSL_TOTAL_TIMEOUT_SECONDS=8
PDF_MAX_PAGES=200
PDF_MERGE_MAX_FILES=20
IMAGE_MAX_PIXELS=40000000
IMAGE_MAX_DIMENSION=10000
CORS_ALLOWED_ORIGINS=http://localhost:4000
ANALYTICS_ENABLED=true
ANALYTICS_INTERNAL_URL=http://analytics:4100
ANALYTICS_TIMEOUT_MS=800
